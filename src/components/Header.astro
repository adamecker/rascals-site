---
import siteData from '../data/site.json';

// Get the current path to determine which link to highlight
const currentPath = Astro.url.pathname;

const navLinks = [
  { href: "/", label: "Home" },
  { href: "/about-us", label: "About Us" },
  { href: "/menu", label: "Menu" },
  { href: "/events", label: "Events" },
  { href: "/gallery", label: "Gallery" },
  { href: "/specials", label: "Specials" },
  { href: "/shop", label: "Shop" },
  { href: "/directions", label: "Directions" },
  { href: "/links", label: "Links" },
  { href: "/contact", label: "Contact" },
];
---

<header class="w-full py-4 sticky top-0 z-50 bg-white/80 backdrop-blur-md border-b border-gray-200 shadow-sm">
  <div class="absolute inset-x-0 top-0 h-2 bg-[linear-gradient(to_right,#E52421_0%,#E52421_16.66%,#F59120_16.66%,#F59120_33.33%,#FDF01A_33.33%,#FDF01A_50%,#399443_50%,#399443_66.66%,#0224D9_66.66%,#0224D9_83.33%,#7916E5_83.33%,#7916E5_100%)]"></div>
  <div class="max-w-6xl mx-auto px-4 flex flex-col lg:flex-row items-center justify-between gap-4 relative">
    
    <a href="/" class="shrink-0 relative z-10 -mt-2 group">
      <img src="/images/logo.png" alt="Rascals Bar Logo" class="h-16 md:h-20 object-contain mx-auto lg:mx-0 group-hover:-translate-y-1 transition-transform" onerror="this.style.display='none'" />
    </a>
    
    <button id="mobile-menu-toggle" class="lg:hidden p-3 rounded-md hover:bg-gray-100 transition-colors focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-gray-300 shadow-md hover:-translate-y-1">
      <svg class="w-8 h-8 text-gray-700" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16m-7 6h7"></path>
      </svg>
    </button>

    <nav class="hidden lg:block w-full lg:w-auto">
      <ul class="flex flex-wrap justify-center lg:justify-end gap-x-4 md:gap-x-5 gap-y-2 text-sm md:text-base font-light tracking-wider uppercase">
        {navLinks.map((link) => (
          <li>
            <a 
              href={link.href} 
              class={`transition-all duration-300 text-gray-700 hover:text-gray-900 p-3 rounded-md shadow-sm hover:shadow-md hover:-translate-y-1 inline-block ${currentPath === link.href || (link.href !== '/' && currentPath.startsWith(link.href)) ? 'text-gray-900 font-normal bg-gray-100 relative after:absolute after:bottom-0 after:left-0 after:h-[3px] after:w-full after:bg-[linear-gradient(to_right,#E52421_0%,#E52421_16.66%,#F59120_16.66%,#F59120_33.33%,#FDF01A_33.33%,#FDF01A_50%,#399443_50%,#399443_66.66%,#0224D9_66.66%,#0224D9_83.33%,#7916E5_83.33%,#7916E5_100%)]' : 'hover:bg-gray-50'}`}
            >
              {link.label}
            </a>
          </li>
        ))}
      </ul>
    </nav>
  </div>
</header>
<div id="mobile-menu-overlay" class="fixed inset-0 bg-white/90 backdrop-blur-lg z-40 hidden flex-col items-center justify-center p-8 transition-opacity duration-300 opacity-0">
  <button id="close-mobile-menu" class="absolute top-4 right-4 p-3 rounded-md hover:bg-gray-100 transition-colors focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-gray-300 shadow-md hover:-translate-y-1">
    <svg class="w-8 h-8 text-gray-700" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
    </svg>
  </button>
  <nav class="w-full text-center">
    <ul class="flex flex-col gap-4">
      {navLinks.map((link) => (
        <li>
          <a 
            href={link.href} 
            class={`block text-4xl font-bold uppercase py-4 transition-colors duration-300 hover:text-gray-900 p-4 rounded-lg shadow-md hover:shadow-lg hover:-translate-y-1 ${currentPath === link.href || (link.href !== '/' && currentPath.startsWith(link.href)) ? 'text-gray-900 bg-gray-100 relative after:absolute after:bottom-0 after:left-0 after:h-[5px] after:w-full after:bg-[linear-gradient(to_right,#E52421_0%,#E52421_16.66%,#F59120_16.66%,#F59120_33.33%,#FDF01A_33.33%,#FDF01A_50%,#399443_50%,#399443_66.66%,#0224D9_66.66%,#0224D9_83.33%,#7916E5_83.33%,#7916E5_100%)]' : 'text-gray-700 hover:bg-gray-50'}`}
          >
            {link.label}
          </a>
        </li>
      ))}
    </ul>
  </nav>
</div>

<script is:inline>
  const mobileMenuToggle = document.getElementById('mobile-menu-toggle');
  const closeMobileMenu = document.getElementById('close-mobile-menu');
  const mobileMenuOverlay = document.getElementById('mobile-menu-overlay');

  mobileMenuToggle.addEventListener('click', () => {
    mobileMenuOverlay.classList.remove('hidden');
    setTimeout(() => {
      mobileMenuOverlay.classList.add('opacity-100');
    }, 10); // Small delay for transition to work
  });

  closeMobileMenu.addEventListener('click', () => {
    mobileMenuOverlay.classList.remove('opacity-100');
    setTimeout(() => {
      mobileMenuOverlay.classList.add('hidden');
    }, 300); // Match transition duration
  });
</script>
