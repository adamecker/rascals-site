---
// src/pages/contact.astro
import Layout from '../layouts/Layout.astro';
import siteData from '../data/site.json';
---

<Layout title="Contact - Rascals Bar">
  <main class="w-full bg-black mt-10 pb-0 px-4">
    <div class="max-w-2xl mx-auto">
      
      <form 
        action={siteData.formspree_endpoint} 
        method="POST" 
        class="bg-cover bg-center border border-neutral-800 p-6 md:p-8 text-left shadow-2xl relative"
        style="background-image: url('/images/contact.png');"
      >
        <div class="bg-black/55 backdrop-blur-xs p-4 mb-4 border-b border-neutral-800/80 text-center">
          <h2 class="text-base md:text-lg font-heading font-bold text-white uppercase tracking-wider leading-relaxed drop-shadow-[0_2px_4px_rgba(0,0,0,0.9)]">
            feel free to contact us with questions or comments!
          </h2>
        </div>
        
        <div class="flex flex-col gap-3">
          <div class="flex flex-col">
            <label class="text-xs uppercase text-white font-bold tracking-widest mb-1 drop-shadow-[0_1.5px_2px_rgba(0,0,0,0.9)]">
              Your Name
            </label>
            <input 
              type="text" 
              name="name"
              placeholder="Name" 
              class="bg-white/80 border border-neutral-400 p-2.5 text-black focus:outline-none focus:border-[#ec4899] focus:bg-white transition-all rounded-none placeholder-gray-600 font-normal"
              required
            />
          </div>

          <div class="flex flex-col">
            <label class="text-xs uppercase text-white font-bold tracking-widest mb-1 drop-shadow-[0_1.5px_2px_rgba(0,0,0,0.9)]">
              Your Email
            </label>
            <input 
              type="email" 
              name="_replyto"
              placeholder="Email" 
              class="bg-white/80 border border-neutral-400 p-2.5 text-black focus:outline-none focus:border-[#ec4899] focus:bg-white transition-all rounded-none placeholder-gray-600 font-normal"
              required
            />
          </div>

          <div class="flex flex-col">
            <label class="text-xs uppercase text-white font-bold tracking-widest mb-1 drop-shadow-[0_1.5px_2px_rgba(0,0,0,0.9)]">
              Question or comment
            </label>
            <textarea 
              name="message"
              rows="3" 
              placeholder="Question or comment" 
              class="bg-white/80 border border-neutral-400 p-2.5 text-black focus:outline-none focus:border-[#ec4899] focus:bg-white transition-all resize-none rounded-none placeholder-gray-600 font-normal"
              required
            ></textarea>
          </div>

          <button 
            type="submit" 
            class="btn bg-white hover:bg-gray-200 text-black border-none rounded-none w-32 uppercase font-light tracking-widest text-xs py-3 mt-1 self-end transition-all shadow-lg"
          >
            send >
          </button>
        </div>
      </form>

    </div>
  </main>
</Layout>