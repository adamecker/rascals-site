---
// src/pages/events.astro
import Layout from '../layouts/Layout.astro';
---

<Layout title="Events - Rascals Bar">
  <main class="w-full bg-black py-16 px-4 text-center min-h-[70vh] flex items-center">
    <div class="max-w-4xl mx-auto w-full">

      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
        <div class="w-full border border-neutral-800 bg-[#111111] p-4 shadow-2xl">
          <img 
            src="/images/birthday.jpg" 
            alt="Rascals Birthday Party Event" 
            class="w-full h-auto object-contain max-h-[500px] mx-auto"
            onerror="this.style.display='none'"
          />
        </div>

        <div class="text-left space-y-6">
          <h2 class="text-3xl md:text-4xl font-heading font-bold uppercase text-white tracking-widest leading-relaxed drop-shadow-md">
            Birthday Party!
          </h2>
          <div class="w-16 h-0.5 bg-[#ec4899] my-4"></div>
          
          <div class="text-lg text-gray-300 font-light leading-relaxed space-y-4">
            <p>
              Have your Birthday Party here and drink for <span class="text-[#ec4899] font-normal uppercase tracking-wider">FREE!</span> 
              Book your party here (either inside or on the patio) with 10 or more guests, and the Birthday boy/girl drinks for 
              <span class="text-[#ec4899] font-normal uppercase tracking-wider">FREE</span> during the party.
            </p>
            <p class="text-sm uppercase tracking-widest text-white font-normal pt-2">
              See Bartender for details!
            </p>
          </div>
        </div>
      </div>

    </div>
  </main>
</Layout>
