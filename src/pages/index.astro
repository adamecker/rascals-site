---
// src/pages/index.astro
import Layout from '../layouts/Layout.astro';
import specialsData from '../data/specials.json';
import { Image } from 'astro:assets';
import gallery1 from '../assets/gallery/gallery-1.jpeg';

// Combine the Happy Hour block and the daily schedule into a single array for the slider
const sliderItems = [
  { title: specialsData.happyHour.title, subtitle: specialsData.happyHour.subtitle },
  ...specialsData.schedule.map(day => ({
    title: day.day.toUpperCase(),
    subtitle: day.sliderText
  }))
];
---

<Layout title="Rascals Bar">
  <main class="w-full bg-black">
    
    <section class="py-8 px-4 max-w-3xl mx-auto">
      <div class="border border-neutral-800 px-6 py-8 text-center bg-[#111111] shadow-2xl min-h-[220px] flex flex-col justify-between relative overflow-hidden">
        <div></div>
        <div class="relative min-h-[140px] flex items-center justify-center">
          {sliderItems.map((special, index) => (
            <div 
              class={`carousel-slide transition-all duration-700 flex flex-col justify-center w-full px-4 text-center ${index === 0 ? 'opacity-100 transform translate-x-0 relative' : 'opacity-0 absolute inset-0 translate-x-full pointer-events-none'}`}
            >
              <h2 class="text-2xl md:text-3xl font-heading font-bold mb-2 text-[#ec4899] uppercase tracking-widest">
                {special.title}
              </h2>
              {index === 0 && <div class="w-12 h-0.5 bg-white mx-auto my-2 opacity-20"></div>}
              <p class={`text-lg md:text-xl font-light text-white leading-relaxed tracking-wider ${index !== 0 ? 'mt-1' : 'uppercase'}`}>
                {special.subtitle}
              </p>
              <a href="/specials" class="mt-4 text-sm text-gray-400 hover:text-[#ec4899] underline underline-offset-4 transition-colors duration-300 z-20 relative block w-max mx-auto">
                View All Specials
              </a>
            </div>
          ))}
        </div>
      
        <div class="flex items-center justify-center gap-4 mt-6 z-10 relative">
          <button id="prev-btn" class="w-7 h-7 flex items-center justify-center border border-gray-700 hover:border-white transition-colors duration-300 focus:outline-none shrink-0" aria-label="Previous">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-3.5 h-3.5 text-white">
              <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 19.5L8.25 12l7.5-7.5" />
            </svg>
          </button>
    
          <div class="flex gap-2 flex-wrap justify-center max-w-[150px]">
            {sliderItems.map((_, index) => (
              <button class={`carousel-dot w-2 h-2 bg-white rounded-full transition-opacity duration-300 ${index === 0 ? 'opacity-100' : 'opacity-30'}`} aria-label={`Slide ${index + 1}`}></button>
            ))}
          </div>

          <button id="next-btn" class="w-7 h-7 flex items-center justify-center border border-gray-700 hover:border-white transition-colors duration-300 focus:outline-none shrink-0" aria-label="Next">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-3.5 h-3.5 text-white">
              <path stroke-linecap="round" stroke-linejoin="round" d="M8.25 4.5l7.5 7.5-7.5 7.5" />
            </svg>
          </button>
        </div>
      </div>
    </section>

    <section class="pb-16 px-4 max-w-4xl mx-auto pt-4">
      <a href="/gallery" class="block border border-neutral-800 shadow-2xl overflow-hidden hover:border-[#ec4899] transition-colors duration-300 group relative bg-[#111111]">
        <Image 
          src={gallery1} 
          alt="Rascals Bar Atmosphere" 
          width={800}
          height={500}
          format="webp"
          class="w-full h-auto max-h-[500px] object-cover mx-auto transition-transform duration-500 opacity-80 group-hover:opacity-100 group-hover:scale-110"
        />
        <div class="absolute inset-0 flex items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity duration-300 bg-black/40">
          <span class="text-[#ec4899] text-4xl drop-shadow-lg">⊕</span>
        </div>
      </a>
    </section>

  </main>
</Layout>

<script>
  let currentSlide = 0;
  const slides = document.querySelectorAll('.carousel-slide');
  const dots = document.querySelectorAll('.carousel-dot');
  const prevBtn = document.getElementById('prev-btn');
  const nextBtn = document.getElementById('next-btn');
  let intervalId;

  function updateCarousel(targetIndex) {
    if (!slides.length) return;
    
    slides.forEach((slide, index) => {
      if (index === targetIndex) {
        slide.classList.remove('opacity-0', 'translate-x-full', '-translate-x-full', 'pointer-events-none', 'absolute', 'inset-0');
        slide.classList.add('opacity-100', 'translate-x-0', 'relative');
        dots[index].classList.replace('opacity-30', 'opacity-100');
      } else {
        slide.classList.remove('opacity-100', 'translate-x-0', 'relative');
        slide.classList.add('opacity-0', 'absolute', 'inset-0', 'pointer-events-none');
        dots[index].classList.replace('opacity-100', 'opacity-30');
        
        if (index < targetIndex) {
          slide.classList.add('-translate-x-full');
          slide.classList.remove('translate-x-full');
        } else {
          slide.classList.add('translate-x-full');
          slide.classList.remove('-translate-x-full');
        }
      }
    });
    currentSlide = targetIndex;
  }

  function nextSlide() {
    let target = currentSlide + 1;
    if (target >= slides.length) target = 0;
    updateCarousel(target);
  }

  function prevSlide() {
    let target = currentSlide - 1;
    if (target < 0) target = slides.length - 1;
    updateCarousel(target);
  }

  function resetInterval() {
    clearInterval(intervalId);
    intervalId = setInterval(nextSlide, 4500);
  }

  prevBtn?.addEventListener('click', () => { prevSlide(); resetInterval(); });
  nextBtn?.addEventListener('click', () => { nextSlide(); resetInterval(); });
  
  dots.forEach((dot, index) => {
    dot.addEventListener('click', () => { updateCarousel(index); resetInterval(); });
  });

  // Init interval
  intervalId = setInterval(nextSlide, 4500);
</script>
