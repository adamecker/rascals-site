---
// src/pages/index.astro
import Layout from '../layouts/Layout.astro';
---

<Layout title="Rascals Bar">
  <main class="w-full bg-black">
    
    <section class="py-8 px-4 max-w-3xl mx-auto">
      <div class="border border-neutral-800 px-6 py-8 text-center bg-[#111111] shadow-2xl min-h-[200px] flex flex-col justify-between relative overflow-hidden">
        <div></div>
        <div class="relative min-h-[100px] flex items-center justify-center">
          <div id="slide-1" class="transition-all duration-700 opacity-100 transform translate-x-0 w-full">
            <h2 class="text-2xl md:text-3xl font-heading font-bold mb-2 text-[#ec4899] uppercase tracking-widest">
              PULL-TAB HAPPY HOUR
            </h2>
            <div class="w-12 h-0.5 bg-white mx-auto my-3 opacity-20"></div>
            <p class="text-lg md:text-xl font-light text-white leading-relaxed uppercase tracking-wider">
              MONDAY-THURSDAY 5PM-8PM
            </p>
          </div>
          <div id="slide-2" class="transition-all duration-700 opacity-0 absolute inset-0 flex flex-col justify-center px-4 translate-x-full pointer-events-none text-center w-full">
            <h2 class="text-2xl md:text-3xl font-heading font-bold text-[#ec4899] uppercase tracking-widest leading-relaxed">
              $2 Off Double Mixer Monday's
            </h2>
          </div>
        </div>
        <div class="flex items-center justify-center gap-4 mt-6 z-10">
          <button id="prev-btn" class="w-7 h-7 flex items-center justify-center border border-gray-700 hover:border-white transition-colors duration-300 focus:outline-none" aria-label="Previous">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-3.5 h-3.5 text-white">
              <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 19.5L8.25 12l7.5-7.5" />
            </svg>
          </button>
          <div class="flex gap-1.5">
            <button id="dot-1" class="w-2 h-2 bg-white rounded-full transition-opacity duration-300 opacity-100" aria-label="Slide 1"></button>
            <button id="dot-2" class="w-2 h-2 bg-white rounded-full transition-opacity duration-300 opacity-30" aria-label="Slide 2"></button>
          </div>
          <button id="next-btn" class="w-7 h-7 flex items-center justify-center border border-gray-700 hover:border-white transition-colors duration-300 focus:outline-none" aria-label="Next">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-3.5 h-3.5 text-white">
              <path stroke-linecap="round" stroke-linejoin="round" d="M8.25 4.5l7.5 7.5-7.5 7.5" />
            </svg>
          </button>
        </div>
      </div>
    </section>

    <section class="pb-16 px-4 max-w-4xl mx-auto">
      <div class="text-center mb-4">
        <h2 class="text-2xl md:text-3xl font-heading font-bold uppercase text-white tracking-widest">
          View Gallery
        </h2>
      </div>
      <a href="/gallery" class="block border border-neutral-800 shadow-2xl overflow-hidden hover:border-[#ec4899] transition-colors duration-300">
        <img 
          src="/images/gallery-1.jpg" 
          alt="Rascals Bar Atmosphere" 
          class="w-full h-auto max-h-[500px] object-contain mx-auto"
          onerror="this.style.display='none'"
        />
      </a>
    </section>

  </main>
</Layout>

<script>
  let currentSlide = 1;
  const slide1 = document.getElementById('slide-1');
  const slide2 = document.getElementById('slide-2');
  const dot1 = document.getElementById('dot-1');
  const dot2 = document.getElementById('dot-2');
  const prevBtn = document.getElementById('prev-btn');
  const nextBtn = document.getElementById('next-btn');

  function updateCarousel(targetSlide: number) {
    if (!slide1 || !slide2 || !dot1 || !dot2) return;
    if (targetSlide === 2) {
      slide1.classList.add('opacity-0', '-translate-x-full');
      slide1.classList.remove('opacity-100', 'translate-x-0');
      slide2.classList.add('opacity-100', 'translate-x-0');
      slide2.classList.remove('opacity-0', 'translate-x-full', 'pointer-events-none');
      dot1.classList.replace('opacity-100', 'opacity-30');
      dot2.classList.replace('opacity-30', 'opacity-100');
      currentSlide = 2;
    } else {
      slide1.classList.add('opacity-100', 'translate-x-0');
      slide1.classList.remove('opacity-0', '-translate-x-full');
      slide2.classList.add('opacity-0', 'translate-x-full', 'pointer-events-none');
      slide2.classList.remove('opacity-100', 'translate-x-0');
      dot1.classList.replace('opacity-30', 'opacity-100');
      dot2.classList.replace('opacity-100', 'opacity-30');
      currentSlide = 1;
    }
  }

  prevBtn?.addEventListener('click', () => updateCarousel(currentSlide === 1 ? 2 : 1));
  nextBtn?.addEventListener('click', () => updateCarousel(currentSlide === 1 ? 2 : 1));
  dot1?.addEventListener('click', () => updateCarousel(1));
  dot2?.addEventListener('click', () => updateCarousel(2));

  setInterval(() => updateCarousel(currentSlide === 1 ? 2 : 1), 4000);
</script>