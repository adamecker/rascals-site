---
// src/pages/[slug].astro
import Layout from '../layouts/Layout.astro';
import pagesData from '../data/pages.json';

// 1. Tell Astro which URLs to generate based on our JSON file keys
export function getStaticPaths() {
  const slugs = Object.keys(pagesData); 
  
  return slugs.map((slug) => {
    return {
      params: { slug },
      props: { page: pagesData[slug as keyof typeof pagesData] }, 
    };
  });
}

// 2. Grab the specific text for whichever page the user clicked
const { page } = Astro.props;
---

<Layout title={`${page.title} | Rascals Bar`}>
  <main class="w-full bg-base-100 py-12 px-4 text-center min-h-[50vh]">
    <div class="max-w-3xl mx-auto">
      
      <h1 class="text-4xl md:text-5xl font-heading font-bold mb-8 uppercase text-primary tracking-wider border-b border-base-300 pb-4 inline-block">
        {page.title}
      </h1>
      
      <div class="text-secondary text-lg leading-relaxed whitespace-pre-line mx-auto max-w-2xl font-light">
        {page.content}
      </div>

    </div>
  </main>
</Layout>