---
// src/pages/[slug].astro
import Layout from '../layouts/Layout.astro';
import pagesData from '../data/pages.json';

export function getStaticPaths() {
  const slugs = Object.keys(pagesData);
  return slugs.map((slug) => {
    return {
      params: { slug },
      props: { page: pagesData[slug as keyof typeof pagesData] }, 
    };
  });
}

const { page } = Astro.props;
const paragraphs = page.content.split('\n\n');
---

<Layout title={`${page.title} | Rascals Bar`}>
  <main class="w-full bg-black py-12 md:py-16 px-4">
    <div class="max-w-3xl mx-auto w-full">

      <div class="space-y-6 text-lg md:text-xl font-light leading-relaxed text-gray-200">
        {paragraphs.map((para) => {
          if (para.includes('http')) {
            const urlRegex = /(https?:\/\/[^\s]+)/g;
            const parts = para.split(urlRegex);
            return (
              <p>
                {parts.map((part) => {
                  if (part.match(urlRegex)) {
                    return (
                      <a href={part} target="_blank" rel="noopener noreferrer" class="text-[#ec4899] hover:text-white transition-colors hover:underline break-all block mt-2 font-bold tracking-widest uppercase text-sm md:text-base">
                        {part}
                      </a>
                    );
                  }
                  return part;
                })}
              </p>
            );
          }
          return <p class="whitespace-pre-line">{para}</p>;
        })}
      </div>

    </div>
  </main>
</Layout>