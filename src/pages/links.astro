---
// src/pages/links.astro
import Layout from '../layouts/Layout.astro';
---

<Layout title="Links - Rascals Bar">
  <main class="w-full bg-gray-50 py-16 px-4 min-h-[70vh] flex items-center">
    <div class="max-w-2xl mx-auto w-full">

      <div class="space-y-6 text-left">
        
        <a 
          href="http://pridefest.com/" 
          target="_blank" 
          rel="noopener noreferrer" 
          class="block bg-white border border-gray-200 p-6 shadow-md hover:border-[#399443] transition-all group"
        >
          <p class="text-gray-900 font-bold tracking-widest uppercase text-base group-hover:text-[#399443] transition-colors mb-1">
            Wisconsin Pridefest
          </p>
          <p class="text-gray-600 text-sm font-light truncate">http://pridefest.com</p>
        </a>

        <a 
          href="http://qrd.org/qrd" 
          target="_blank" 
          rel="noopener noreferrer" 
          class="block bg-white border border-gray-200 p-6 shadow-md hover:border-[#399443] transition-all group"
        >
          <p class="text-gray-900 font-bold tracking-widest uppercase text-base group-hover:text-[#399443] transition-colors mb-1">
            Queer Resources Directory
          </p>
          <p class="text-gray-600 text-sm font-light truncate">http://qrd.org/qrd</p>
        </a>

        <a 
          href="http://gayscape.com/" 
          target="_blank" 
          rel="noopener noreferrer" 
          class="block bg-white border border-gray-200 p-6 shadow-md hover:border-[#399443] transition-all group"
        >
          <p class="text-gray-900 font-bold tracking-widest uppercase text-base group-hover:text-[#399443] transition-colors mb-1">
            GayScape
          </p>
          <p class="text-gray-600 text-sm font-light truncate">http://gayscape.com</p>
        </a>

        <a 
          href="http://gerberhart.org/" 
          target="_blank" 
          rel="noopener noreferrer" 
          class="block bg-white border border-gray-200 p-6 shadow-md hover:border-[#399443] transition-all group"
        >
          <p class="text-gray-900 font-bold tracking-widest uppercase text-base group-hover:text-[#399443] transition-colors mb-1">
            Gerber/Hart Library
          </p>
          <p class="text-gray-600 text-sm font-light truncate">http://gerberhart.org</p>
        </a>

        <a 
          href="http://glnh.org/" 
          target="_blank" 
          rel="noopener noreferrer" 
          class="block bg-white border border-gray-200 p-6 shadow-md hover:border-[#399443] transition-all group"
        >
          <p class="text-gray-900 font-bold tracking-widest uppercase text-base group-hover:text-[#399443] transition-colors mb-1">
            National LGBT Help Center
          </p>
          <p class="text-gray-600 text-sm font-light truncate">http://glnh.org</p>
        </a>

        <a 
          href="http://gaydata.com/" 
          target="_blank" 
          rel="noopener noreferrer" 
          class="block bg-white border border-gray-200 p-6 shadow-md hover:border-[#399443] transition-all group"
        >
          <p class="text-gray-900 font-bold tracking-widest uppercase text-base group-hover:text-[#399443] transition-colors mb-1">
            Gay Media Database
          </p>
          <p class="text-gray-600 text-sm font-light truncate">http://gaydata.com</p>
        </a>

        <a 
          href="https://www.testing.com/std-testing/appleton-wi/" 
          target="_blank" 
          rel="noopener noreferrer" 
          class="block bg-white border border-gray-200 p-6 shadow-md hover:border-[#399443] transition-all group"
        >
          <p class="text-gray-900 font-bold tracking-widest uppercase text-base group-hover:text-[#399443] transition-colors mb-1">
            STD Testing and Prevention
          </p>
          <p class="text-gray-600 text-sm font-light truncate">https://www.testing.com/std-testing/appleton-wi</p>
        </a>

      </div>

    </div>
  </main>
</Layout>
