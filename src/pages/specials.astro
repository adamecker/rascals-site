---
// src/pages/specials.astro
import Layout from '../layouts/Layout.astro';
import specialsData from '../data/specials.json';
---

<Layout title="Specials - Rascals Bar">
  <main class="w-full bg-black py-12 px-4 min-h-[75vh] flex items-center">
    <div class="max-w-2xl mx-auto w-full">

      <div class="space-y-8 text-xl font-light leading-relaxed text-gray-300 text-left">
        
        {specialsData.schedule.map((dayData, index) => (
          <div class={index !== specialsData.schedule.length - 1 ? "border-b border-neutral-900 pb-5" : ""}>
            <p class="text-white font-bold tracking-wider uppercase text-lg mb-1.5">{dayData.day}</p>
            <div class="space-y-1 text-gray-400 text-[17px]">
              {dayData.items.map(item => (
                <p set:html={item}></p>
              ))}
              {dayData.highlight && (
                <p class="text-[#ec4899] font-medium text-sm tracking-wider uppercase pt-1">{dayData.highlight}</p>
              )}
            </div>
          </div>
        ))}

      </div>

    </div>
  </main>
</Layout>