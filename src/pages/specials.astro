---
// src/pages/specials.astro
import Layout from '../layouts/Layout.astro';
---

<Layout title="Specials - Rascals Bar">
  <main class="w-full bg-black py-12 px-4 min-h-[75vh] flex items-center">
    <div class="max-w-2xl mx-auto w-full">

      <div class="space-y-8 text-xl font-light leading-relaxed text-gray-300 text-left">
        
        <div class="border-b border-neutral-900 pb-5">
          <p class="text-white font-bold tracking-wider uppercase text-lg mb-1.5">Monday</p>
          <div class="space-y-1 text-gray-400 text-[17px]">
            <p>Pull-Tab Happy Hour 5-8 pm</p>
            <p>$2 Off Double Mixers</p>
            <p class="text-[#ec4899] font-medium text-sm tracking-wider uppercase pt-1">2-4-1 Power Hour at Midnight</p>
          </div>
        </div>

        <div class="border-b border-neutral-900 pb-5">
          <p class="text-white font-bold tracking-wider uppercase text-lg mb-1.5">Tuesday</p>
          <div class="space-y-1 text-gray-400 text-[17px]">
            <p class="text-white/90 font-medium">Ladies Night</p>
            <p>Pull-Tab Happy Hour 5-8 pm</p>
            <p>$3.00 Pints of Domestic Beer</p>
            <p>$4.00 Rail Pints for the Ladies</p>
            <p class="text-[#ec4899] font-medium text-sm tracking-wider uppercase pt-1">2-4-1 Power Hour at Midnight</p>
          </div>
        </div>

        <div class="border-b border-neutral-900 pb-5">
          <p class="text-white font-bold tracking-wider uppercase text-lg mb-1.5">Wednesday</p>
          <div class="space-y-1 text-gray-400 text-[17px]">
            <p>Pull-Tab Happy Hour 5-8 pm</p>
            <p>All Rail Drinks $0.50 off all night</p>
            <p class="text-[#ec4899] font-medium text-sm tracking-wider uppercase pt-1">2-4-1 Power Hour at Midnight</p>
          </div>
        </div>

        <div class="border-b border-neutral-900 pb-5">
          <p class="text-white font-bold tracking-wider uppercase text-lg mb-1.5">Thursday</p>
          <div class="space-y-1 text-gray-400 text-[17px]">
            <p>Pull-Tab Happy Hour 5-8 pm</p>
            <p>$3.00 Pints of Domestic Beer</p>
            <p class="text-[#ec4899] font-medium text-sm tracking-wider uppercase pt-1">2-4-1 Power Hour at Midnight</p>
          </div>
        </div>

        <div class="border-b border-neutral-900 pb-5">
          <p class="text-white font-bold tracking-wider uppercase text-lg mb-1.5">Friday</p>
          <div class="space-y-1 text-gray-400 text-[17px]">
            <p>Fish Fry from 5-9 pm</p>
          </div>
        </div>

        <div class="border-b border-neutral-900 pb-5">
          <p class="text-white font-bold tracking-wider uppercase text-lg mb-1.5">Saturday</p>
          <div class="space-y-1 text-gray-400 text-[17px]">
            <p>Domestic tap beer/Rail Liquor $12</p>
            <p>Bottle Beer/Non-Rail Liquor $20 <span class="text-xs text-gray-500 uppercase tracking-widest">(No Shots)</span></p>
            <p class="text-[#ec4899] font-medium text-sm tracking-wider uppercase pt-1">BEER/LIQUOR BUST FROM 10-MIDNIGHT</p>
          </div>
        </div>

        <div>
          <p class="text-white font-bold tracking-wider uppercase text-lg mb-1.5">Sunday</p>
          <div class="space-y-1 text-gray-400 text-[17px]">
            <p>Beer Bust from 2-7 pm for $15</p>
            <p>Free fries with sandwich purchase</p>
          </div>
        </div>

      </div>

    </div>
  </main>
</Layout>
