---
// src/pages/shop.astro
import Layout from '../layouts/Layout.astro';

const merchandise = [
  {
    name: "Tank",
    image: "/images/shop-tank.png",
    description: "See bartender for details."
  },
  {
    name: "Hoodie",
    image: "/images/shop-hoodie.png",
    description: "See bartender for details."
  },
  {
    name: "Koozie",
    image: "/images/shop-koozie.png",
    description: "See bartender for details."
  }
];
---

<Layout title="Shop | Rascals Bar">
  <main class="w-full bg-black py-12 md:py-16 px-4 text-center">
    <div class="max-w-5xl mx-auto space-y-12">
      
      <div class="space-y-4">
        <h3 class="text-[#ec4899] text-xs md:text-sm font-bold uppercase tracking-[0.2em] opacity-90">Merchandise</h3>
        <p class="text-gray-300 text-base md:text-lg font-normal tracking-wide max-w-2xl mx-auto">
          Take a piece of Rascals home with you!
        </p>
        <div class="w-16 h-[1px] bg-gradient-to-r from-transparent via-[#ec4899] to-transparent mx-auto mt-4"></div>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8 max-w-5xl mx-auto">
        {merchandise.map((item, index) => (
          <button 
            data-index={index}
            class="shop-trigger group flex flex-col bg-[#111111] border border-neutral-800 p-6 shadow-2xl transition-all duration-500 hover:border-[#ec4899]/50 hover:shadow-[0_0_40px_rgba(236,72,153,0.15)] rounded-sm text-center focus:outline-none"
          >
            <div class="aspect-[4/5] flex items-center justify-center overflow-hidden mb-6 p-2">
              <img 
                src={item.image} 
                alt={item.name} 
                class="max-w-full max-h-full h-auto w-auto object-contain transition-transform duration-700 group-hover:scale-105"
              />
            </div>

            <div class="space-y-2 w-full mt-auto">
              <h3 class="text-xl font-bold text-white uppercase tracking-widest group-hover:text-[#ec4899] transition-colors">
                {item.name}
              </h3>
              <p class="text-gray-400 text-sm font-light tracking-wider italic">
                {item.description}
              </p>
            </div>
          </button>
        ))}
      </div>
    </div>
  </main>

  <div id="shop-lightbox" class="fixed inset-0 z-50 hidden bg-black/95 flex items-center justify-center backdrop-blur-sm transition-opacity duration-300 opacity-0">
    <button id="close-shop" class="absolute top-4 right-4 md:top-8 md:right-8 text-gray-400 hover:text-[#ec4899] transition-colors z-50 p-2">
      <svg class="w-8 h-8 md:w-10 md:h-10" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
    </button>
    
    <button id="prev-shop" class="absolute left-2 md:left-8 top-1/2 -translate-y-1/2 text-gray-400 hover:text-[#ec4899] transition-colors p-2 z-50">
       <svg class="w-10 h-10 md:w-14 md:h-14" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path></svg>
    </button>
    
    <button id="next-shop" class="absolute right-2 md:right-8 top-1/2 -translate-y-1/2 text-gray-400 hover:text-[#ec4899] transition-colors p-2 z-50">
      <svg class="w-10 h-10 md:w-14 md:h-14" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path></svg>
    </button>

    <div class="relative w-full max-w-4xl max-h-screen p-8 flex items-center justify-center">
       <img id="shop-lightbox-img" src="" alt="Merchandise Fullscreen" class="max-w-full max-h-[85vh] object-contain transition-opacity duration-300" />
    </div>
  </div>
</Layout>

<script>
  const shopTriggers = document.querySelectorAll('.shop-trigger');
  const shopLightbox = document.getElementById('shop-lightbox');
  const shopImg = document.getElementById('shop-lightbox-img') as HTMLImageElement;
  const closeShop = document.getElementById('close-shop');
  const prevShop = document.getElementById('prev-shop');
  const nextShop = document.getElementById('next-shop');
  
  const shopImages = [
    "/images/shop-tank.png",
    "/images/shop-hoodie.png",
    "/images/shop-koozie.png"
  ];
  
  let currentShopIndex = 0;

  function updateShopImage(index: number) {
    if (shopImg) {
      shopImg.style.opacity = '0';
      setTimeout(() => {
        shopImg.src = shopImages[index];
        shopImg.style.opacity = '1';
      }, 150);
    }
  }

  function openShopLightbox(index: number) {
    currentShopIndex = index;
    if (shopImg) shopImg.src = shopImages[currentShopIndex];
    if (shopLightbox) {
      shopLightbox.classList.remove('hidden');
      setTimeout(() => {
        shopLightbox.classList.remove('opacity-0');
        shopLightbox.classList.add('opacity-100');
      }, 10);
    }
    document.body.style.overflow = 'hidden';
  }

  function closeShopModal() {
    if (shopLightbox) {
      shopLightbox.classList.remove('opacity-100');
      shopLightbox.classList.add('opacity-0');
      setTimeout(() => {
        shopLightbox.classList.add('hidden');
      }, 300);
    }
    document.body.style.overflow = '';
  }

  shopTriggers.forEach(trigger => {
    trigger.addEventListener('click', () => {
      const index = parseInt(trigger.getAttribute('data-index') || '0');
      openShopLightbox(index);
    });
  });

  closeShop?.addEventListener('click', closeShopModal);
  
  nextShop?.addEventListener('click', () => {
    currentShopIndex = (currentShopIndex + 1) % shopImages.length;
    updateShopImage(currentShopIndex);
  });

  prevShop?.addEventListener('click', () => {
    currentShopIndex = (currentShopIndex - 1 + shopImages.length) % shopImages.length;
    updateShopImage(currentShopIndex);
  });

  shopLightbox?.addEventListener('click', (e) => {
    if (e.target === shopLightbox) closeShopModal();
  });

  document.addEventListener('keydown', (e) => {
    if (shopLightbox && !shopLightbox.classList.contains('hidden')) {
      if (e.key === 'Escape') closeShopModal();
      if (e.key === 'ArrowRight') nextShop?.click();
      if (e.key === 'ArrowLeft') prevShop?.click();
    }
  });
</script>