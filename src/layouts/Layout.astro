---
// src/layouts/Layout.astro
import siteData from '../data/site.json';
import '../styles/global.css';
import { ViewTransitions } from 'astro:transitions';
import Header from '../components/Header.astro';

const { title } = Astro.props;
---

<!doctype html>
<html lang="en" class="bg-white text-gray-900 overflow-x-hidden">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Fira+Sans:wght@300;400;600&family=Montserrat:wght@400;700&display=swap" rel="stylesheet">
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png">
    <link rel="manifest" href="/site.webmanifest">
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png">
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png">
    <ViewTransitions />
	</head>
	<body class="flex flex-col min-h-screen bg-white font-sans antialiased text-gray-900 overflow-x-hidden">
        
    <Header />

    <div class="marquee-container bg-gray-100 py-4 border-y border-gray-200 overflow-hidden relative mb-8">
      <div class="marquee-content whitespace-nowrap text-3xl md:text-4xl font-extrabold uppercase text-gray-800 tracking-wider">
        <span class="inline-block px-8">PULL-TAB HAPPY HOUR &bull; GREAT MUSIC &bull; DAILY DRINK SPECIALS &bull;</span>
        <span class="inline-block px-8">PULL-TAB HAPPY HOUR &bull; GREAT MUSIC &bull; DAILY DRINK SPECIALS &bull;</span>
        <span class="inline-block px-8">PULL-TAB HAPPY HOUR &bull; GREAT MUSIC &bull; DAILY DRINK SPECIALS &bull;</span>
      </div>
    </div>

    <style>
      @keyframes marquee {
        0% { transform: translateX(0%); }
        100% { transform: translateX(-50%); } /* Half the width because we duplicate the content */
      }

      .marquee-content {
        animation: marquee 30s linear infinite; /* Adjust duration as needed */
      }
    </style>

		<slot />

    <footer class="mt-auto py-12 bg-gray-50 border-t border-gray-200">
      <div class="text-center text-gray-600 leading-relaxed px-4 flex flex-col items-center">
        <p class="text-lg mb-1">{siteData.email}</p>
        <p class="text-lg">{siteData.phone}</p>
        <p class="text-lg mb-4">{siteData.address}</p>
        
        <div class="mb-8">
          <a 
            href="https://www.facebook.com/rascals.appleton" 
            target="_blank" 
            rel="noopener noreferrer" 
            class="w-10 h-10 rounded-full overflow-hidden transition-transform hover:scale-110 flex items-center justify-center shadow-md hover:shadow-lg bg-[#3b5998] hover:-translate-y-1 p-3"
            aria-label="Facebook"
          >
            <img src="/images/facebook.png" alt="Facebook" class="w-full h-full object-cover" onerror="this.src='https://upload.wikimedia.org/wikipedia/commons/b/b8/2021_Facebook_icon.svg'" />
          </a>
        </div>
        
        <p class="font-bold text-gray-900 uppercase tracking-widest mb-2">Hours</p>
        {siteData.hours.map((hour) => (
          <p class="text-gray-700">{hour}</p>
        ))}
      </div>
    </footer>
    
	</body>
</html>
